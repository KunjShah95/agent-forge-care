# Example environment variables for local development
# Copy to `.env` and fill values before running the backend

# Primary database
DATABASE_URL=postgres://user:password@localhost:5432/agentforge

# Redis (optional, used for caching and background queues)
REDIS_URL=redis://localhost:6379/0

# Secrets and auth
SECRET_KEY=replace-with-a-random-secret
FIREBASE_CREDENTIALS_JSON=./path/to/firebase-credentials.json

# LLM / Embeddings provider
OPENAI_API_KEY=replace-with-openai-key
# or, for Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# Frontend Firebase (Vite) configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_EMULATOR_HOST=

# Vector DB config (Pinecone/Chroma/Weaviate/etc.)
VECTOR_DB_PROVIDER=faiss
VECTOR_DB_HOST=
VECTOR_DB_API_KEY=

# File storage (development: local; production: S3/GCS)
STORAGE_BACKEND=local
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# Optional: Sentry / monitoring
SENTRY_DSN=
