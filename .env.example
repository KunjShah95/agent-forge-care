# ════════════════════════════════════════════════════════════════
# AgentForge Career OS — Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# The backend config.py reads from .env in the backend/ directory.
# The frontend uses VITE_* vars; they are injected at build time by Vite
# and must be set in Vercel Project Settings → Environment Variables.
#
# Quick Start:
#   1. cp .env.example .env
#   2. Fill in secrets (Firebase config + at least one API key)
#   3. Deploy backend to Railway (automatically gets DATABASE_URL, REDIS_URL)
#   4. Deploy frontend to Vercel (set VITE_* vars in Project Settings)
# ════════════════════════════════════════════════════════════════


# ─── Application ──────────────────────────────────────────────
DEBUG=false
PORT=8000
APP_NAME=AgentForge Career OS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ─── Database (PostgreSQL) ────────────────────────────────────
# Railway auto-provides DATABASE_URL when PostgreSQL is added.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentforge


# ─── Qdrant Vector Store ──────────────────────────────────────
QDRANT_URL=http://localhost:6333


# ─── Redis (Caching / Job Queues) ─────────────────────────────
# Railway auto-provides REDIS_URL when Redis is added.
REDIS_URL=redis://localhost:6379


# ─── Firebase (Backend — ID token verification) ───────────────
# REQUIRED in production.
# Find it at https://console.firebase.google.com → Project Settings → General
FIREBASE_PROJECT_ID=your-firebase-project-id


# ─── JWT / Auth ───────────────────────────────────────────────
# Auto-generated by config.py if left empty.
# For production, set a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Auto-generated if empty
SECRET_KEY=


# ─── Security ─────────────────────────────────────────────────
GITHUB_TOKEN=
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5


# ─── AI Model Providers ──────────────────────────────────────
# At least ONE is required for agents to function.
# Providers are tried in priority order with automatic fallback.
# Priority: OpenAI → Anthropic → Gemini → DeepSeek → Groq → Mistral → Together → Fireworks → OpenRouter → Ollama

# OpenAI (paid, highest priority — GPT-4o, embeddings)
OPENAI_API_KEY=

# Anthropic Claude (paid, great for complex reasoning)
ANTHROPIC_API_KEY=

# Google Gemini (free tier: 60 req/min — Gemini 2.0 Flash + embeddings)
GOOGLE_API_KEY=

# DeepSeek (very cheap, open-source reasoning model)
DEEPSEEK_API_KEY=

# Groq (free tier — fast Llama 3.3 70B inference)
GROQ_API_KEY=

# Mistral AI (free tier available)
MISTRAL_API_KEY=

# Together AI (paid, open-source model catalog)
TOGETHER_API_KEY=

# Fireworks AI (free $1 trial credits, OpenAI-compatible)
FIREWORKS_API_KEY=

# OpenRouter (gateway to 200+ models, free tier)
OPENROUTER_API_KEY=

# Ollama (free, local — just set the base URL)
OLLAMA_BASE_URL=http://localhost:11434

# HuggingFace (for embeddings fallback if no OpenAI/Gemini key)
HUGGINGFACE_API_KEY=


# ─── Embeddings / Reranking ───────────────────────────────────
# Cohere is used for cross-encoder reranking of search results
COHERE_API_KEY=


# ─── Observability (LangSmith) ────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentforge-career-os
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# ─── Email (SendGrid) ─────────────────────────────────────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@agentforge.ai


# ─── Search APIs ──────────────────────────────────────────────
# Falls back to web scraping if none configured.

# Google Custom Search (requires both CSE ID + Google API key)
GOOGLE_CSE_ID=
# SerpAPI (Google Jobs structured results)
SERPAPI_KEY=
# Tavily (AI-native search, best for agent use)
TAVILY_API_KEY=
# Brave Search (free: 2,000 queries/month)
BRAVE_API_KEY=
# Exa (AI-native semantic search)
EXA_API_KEY=
# Mojeek (privacy-first search engine)
MOJEEK_API_KEY=
# Self-hosted SearXNG meta search engine
SEARXNG_BASE_URL=


# ─── Match Scoring Weights ────────────────────────────────────
MATCH_PROFILE_WEIGHT=0.7
MATCH_EXTERNAL_WEIGHT=0.3


# ════════════════════════════════════════════════════════════════
# FRONTEND — Vite Environment Variables
# All frontend env vars MUST start with VITE_ to be exposed to the client.
# Set these in Vercel Project Settings → Environment Variables.
# ════════════════════════════════════════════════════════════════

# ─── Firebase Web App Config ──────────────────────────────────
# REQUIRED. Find these in Firebase Console:
#   Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX

# ─── API URL ──────────────────────────────────────────────────
# Set this to your deployed Railway backend URL.
# Railway provides the URL after first deployment.
# Example: https://agentforge-backend.up.railway.app
VITE_API_URL=https://your-backend-url.up.railway.app


# ════════════════════════════════════════════════════════════════
# Deployment Overrides
# ════════════════════════════════════════════════════════════════
# Railway auto-sets: PORT, DATABASE_URL, REDIS_URL, RAILWAY_PUBLIC_DOMAIN
# Vercel auto-sets: VERCEL_URL (for preview deployments)
