# ═══════════════════════════════════════════════════════════════════════
# .env.staging
#
# Staging environment variables for AgentForge Career OS.
# Copy this file to .env or set these as env vars in your CI/CD pipeline.
#
# Usage:
#   cp .env.staging .env   # Then edit with your actual values
#   docker compose -f docker-compose.staging.yml up
# ═══════════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────
JWT_SECRET=staging-change-me-to-a-unique-random-secret
FIREBASE_PROJECT_ID=your-staging-firebase-project

# ── Frontend (required for the staging frontend build) ──────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-staging-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-staging-firebase-project
VITE_FIREBASE_STORAGE_BUCKET=your-staging-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ── AI Model Providers (at least one) ──────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=sk-...
# TOGETHER_API_KEY=...
# FIREWORKS_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# ── Search APIs (optional) ─────────────────────────────────────────
# TAVILY_API_KEY=tvly-...
# SERPAPI_KEY=...
# BRAVE_API_KEY=...
# EXA_API_KEY=...
# MOJEEK_API_KEY=...
# SEARXNG_BASE_URL=...

# ── Other Services (optional) ──────────────────────────────────────
# COHERE_API_KEY=...
# SENDGRID_API_KEY=...
# LANGCHAIN_API_KEY=...

# ── Data Retention Overrides (staging defaults — shorter than prod) ─
# DATA_RETENTION_OPPORTUNITY_DAYS=30
# DATA_RETENTION_AGENT_TASK_DAYS=14
# DATA_RETENTION_NOTIFICATION_DAYS=7
# DATA_RETENTION_MEMORY_DAYS=30
