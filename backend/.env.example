# ════════════════════════════════════════════════════════════════
# AgentForge Career OS — Backend Environment Configuration
# Copy this to .env and fill in your API keys.
# ════════════════════════════════════════════════════════════════

# ─── Application ────────────────────────────────────────────────
APP_NAME=AgentForge Career OS
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# ─── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentforge

# ─── Qdrant Vector Store ────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Redis (Caching / Job Queues) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Firebase (ID token verification) ───────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CREDENTIALS_JSON=./firebase-credentials.json

# ─── JWT / Auth ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SECRET_KEY=replace-with-a-long-random-secret-key

# ─── AI Model Providers ────────────────────────────────────────
# At least ONE is required for agents to function.

# OpenAI (paid — GPT-4o, embeddings) — RECOMMENDED
OPENAI_API_KEY=sk-...

# Anthropic Claude (paid — Claude Sonnet 4, Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (free tier: 60 req/min — Gemini 2.0 Flash + embeddings)
GOOGLE_API_KEY=...

# Groq (free tier — fast Llama 3.3 70B inference)
GROQ_API_KEY=gsk_...

# DeepSeek (very cheap — deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=...

# Mistral AI (free tier — Mistral Large/Small)
MISTRAL_API_KEY=...

# OpenRouter (gateway to 200+ models, free tier available)
OPENROUTER_API_KEY=sk-or-...

# Together AI (OpenAI-compatible, wide open-source model catalog)
TOGETHER_API_KEY=...

# Fireworks AI (OpenAI-compatible, $1 free starter credits)
FIREWORKS_API_KEY=...

# Ollama (free, local — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Embeddings / Reranking ────────────────────────────────────

# HuggingFace (optional — embeddings via inference API)
HUGGINGFACE_API_KEY=hf_...

# Cohere (reranking job/candidate search results)
COHERE_API_KEY=...

# ─── Search APIs ────────────────────────────────────────────────

# Tavily (AI-native search for research agent)
TAVILY_API_KEY=tvly-...

# Google Custom Search Engine (free: 100 queries/day)
GOOGLE_CSE_ID=...

# Brave Search (free: 2,000 queries/month)
BRAVE_API_KEY=...

# Exa (AI-native search)
EXA_API_KEY=...

# SerpAPI (Google Jobs structured results)
SERPAPI_KEY=...

# Mojeek (privacy-focused search, free tier)
MOJEEK_API_KEY=...

# SearXNG (self-hosted meta search engine)
SEARXNG_BASE_URL=

# ─── GitHub API ─────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ─── Email (SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@agentforge.ai

# ─── Observability (LangSmith) ─────────────────────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentforge-career-os

# ─── Match Scoring Weights ─────────────────────────────────────
MATCH_PROFILE_WEIGHT=0.7
MATCH_EXTERNAL_WEIGHT=0.3

# ─── Sentry (Error Tracking) ───────────────────────────────────
SENTRY_DSN=

# ─── File Storage (dev: local; prod: S3) ──────────────────────
STORAGE_BACKEND=local
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
