# AgentForge Career OS — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ─── Application ────────────────────────────────────────────
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-secret-key

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentforge

# ─── Qdrant (Vector Search) ─────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Redis (Caching / Queues) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── OpenAI (Embeddings + LLM Goal Decomposition) ──────────
OPENAI_API_KEY=sk-...

# ─── Cohere (Reranking job/candidate matches) ──────────────
COHERE_API_KEY=...

# ─── LangSmith (Observability & Tracing) ───────────────────
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentforge-career-os

# ─── Search APIs (Optional — falls back to demo data) ──────
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
SERPAPI_KEY=
